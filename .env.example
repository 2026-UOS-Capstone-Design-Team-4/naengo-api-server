# ============================================================
# naengo-api-server 환경변수 템플릿 (커밋됨 — 실 secret 절대 넣지 말 것)
# 사용: 이 파일을 복사해 .env 로 만들고 값 채움. .env 는 .gitignore 됨.
# 로컬 적용: git-bash 기준  set -a; source .env; set +a; ./gradlew bootRun --args='--spring.profiles.active=local'
#  ⚠️ .env 는 반드시 LF 줄바꿈. CRLF 면 source 시 값 끝에 \r 가 붙어 KAKAO_REDIRECT_URI 불일치(KOE006) 등 발생.
#  ⚠️ Spring 이 .env 를 자동 로드하지 않음(dotenv 의존성 없음). 위처럼 source 하거나 IDE EnvFile/Run Config 로 주입.
# ============================================================

# ── 카카오 소셜 (로컬 e2e 필수 / 운영 필수) ──────────────────
# 카카오 개발자 콘솔 > 앱 키 > REST API 키. 설정 절차: docs/kakao-oauth-runbook.md
KAKAO_REST_API_KEY=
# 콘솔 Redirect URI 와 문자 단위 완전 일치. 로컬 기본:
KAKAO_REDIRECT_URI=http://localhost:8080/oauth/kakao/test-callback

# ── JWT (로컬 생략 가능: application-local.yml 기본값 존재 / 운영 필수) ──
# 32바이트(=ASCII 32자) 이상. 생성: openssl rand -base64 48
# ⚠️ 운영 값은 AI 서버와 "동일 값" 공유 필수(AI 가 같은 secret 으로 우리 JWT 검증 — Phase 0-1 / D-2)
JWT_SECRET=

# ── DB (로컬 생략 가능: docker-compose + application-local.yml 기본값 / 운영 필수) ──
DB_URL=jdbc:postgresql://<host>:5432/naengo
DB_USERNAME=naengo
DB_PASSWORD=

# ── CORS (운영 필수 — 미주입 시 부팅 실패) ───────────────────
# 콤마 구분. 운영 front/admin 도메인. 로컬은 application.yml 기본값(localhost:3000,5173) 사용.
CORS_ALLOWED_ORIGINS=https://front.example.com,https://admin.example.com

# ── 쿠키 (운영) ─────────────────────────────────────────────
# prod 는 secure=true 고정(HTTPS 필수). 크로스도메인 front 면 None 로:
AUTH_COOKIE_SAME_SITE=Lax
# 멀티 서브도메인이면 .example.com, 아니면 비움(호스트 한정):
AUTH_COOKIE_DOMAIN=

# ── AWS S3 (이미지 업로드 — 미준비면 비워두면 업로드 endpoint 503, 의도) ──
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_S3_PUBLIC_URL_PREFIX=
